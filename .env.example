APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=monoland
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.myasn.test
SANCTUM_STATEFUL_DOMAINS=myasn.test
SANCTUM_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

OCTANE_SERVER=swoole

WORKUNIT_NAME="Monoland Software"
WORKUNIT_REGION="Provinsi Banten"

MIX_PUSHER_ENABLE=false
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

MIX_DEV_NAME=myasn
MIX_DEV_DOMAIN=myasn.test
MIX_DEV_PROTOCOL=http
MIX_DEV_ROUTERMODE=hash

MIX_PRD_NAME=
MIX_PRD_DOMAIN=
MIX_PRD_PROTOCOL=
MIX_PRD_ROUTERMODE=

MIX_PAGE_DASHBOARD=myaccount-dashboard
MIX_PAGE_LANDING=default-landing
MIX_PAGE_LOGIN=account-login
MIX_PAGE_THEME=light-blue
MIX_PAGE_ITEMPERPAGE=10